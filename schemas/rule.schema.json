{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://athena.dev/policy-replay/rule.schema.json",
  "title": "PolicyReplay rule spec",
  "type": "object",
  "required": ["rule_id", "name", "proposing_body", "proposal_date", "effective_target_date", "affected_markets", "parameter_overrides", "references"],
  "additionalProperties": false,
  "properties": {
    "rule_id": {"type": "string"},
    "name": {"type": "string"},
    "proposing_body": {"type": "string", "enum": ["FERC", "ISO", "PUC"]},
    "proposal_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "effective_target_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "affected_markets": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "parameter_overrides": {"type": "object", "additionalProperties": {"type": "number"}},
    "references": {"type": "array", "minItems": 2, "items": {"type": "string", "format": "uri"}}
  }
}

